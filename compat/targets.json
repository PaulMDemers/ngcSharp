{
  "schema": "ngcsharp.compat-targets.v1",
  "description": "Curated local compatibility targets. Paths may point at ignored artifacts or user-provided retail images.",
  "defaults": {
    "timeoutSeconds": 60,
    "traceTail": 32,
    "profilePc": 12,
    "fastForwardIdle": true,
    "noRegisters": true,
    "quiet": true
  },
  "targets": [
    {
      "id": "smoke-dol",
      "name": "Synthetic smoke DOL",
      "type": "dol",
      "path": "artifacts/smoke.dol",
      "suites": [ "quick", "smoke" ],
      "tags": [ "cpu", "loader", "memory" ],
      "maxInstructions": 32,
      "timeoutSeconds": 15,
      "expected": {
        "status": "ok",
        "stopReason": "halted"
      }
    },
    {
      "id": "xfb-smoke",
      "name": "Source-built XFB smoke fixture",
      "type": "dol",
      "path": "artifacts/devkitpro/xfb-smoke.dol",
      "suites": [ "quick", "homebrew", "xfb" ],
      "tags": [ "vi", "xfb", "framebuffer" ],
      "maxInstructions": 1000000,
      "timeoutSeconds": 30,
      "xfbFrame": {
        "address": "0x81200000",
        "width": 4,
        "height": 2,
        "format": "rgb565"
      },
      "expected": {
        "status": "ok",
        "stopReason": "max-instructions",
        "frameSha256": "f5936788ea8fb2ec08688a5e2e87c3804af5bcb85b4aa66603ed83bdf40773b8"
      }
    },
    {
