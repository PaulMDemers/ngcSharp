      "tags": [ "gx", "tev", "texture", "efb-copy", "xfb" ],
      "maxInstructions": 3000000,
      "timeoutSeconds": 45,
      "gxFrame": {
        "source": "auto",
        "maxDraws": 160,
        "maxRasterPixels": 12000000
      },
      "expected": {
        "status": "ok",
        "stopReason": "max-instructions",
        "minGxFifoBytes": 1,
        "minRenderedTriangles": 12,
        "frameSha256": "53d72e2558aada66e9f6ba11e2bf28dfa3fed66e19b2ce50c23de3dee05d65ae"
